{
  "name": "@rpg-engine/core",
  "version": "0.1.0",
  "description": "Core game engine for the RPG graph engine — types, store, dice, narrative, queries",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  }
}
